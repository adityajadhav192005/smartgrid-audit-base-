# Required for dashboard auth on Vercel
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public backend for live health/blockchain/SCADA routes
SMARTGRID_API_URL=https://smartgrid-public-api-1001036509634.us-central1.run.app

# REQUIRED in production. Generate a strong random secret, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# and set the SAME value on the backend (Cloud Run env var SMARTGRID_API_KEY).
# Do NOT commit the real value. Never use 'smartgrid-dev-key' in production
# — the backend refuses it when SMARTGRID_ENV=production.
SMARTGRID_API_KEY=replace-with-strong-random-secret
