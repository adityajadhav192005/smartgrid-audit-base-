# Exclude everything by default for Cloud Build source upload
*

# Include only files needed by Docker build
!Dockerfile
!requirements.txt
!backend_railway/**
!smartgrid_mas/**

# Exclude runtime/cache artifacts even inside included trees
backend_railway/data/*.db
backend_railway/__pycache__/**
smartgrid_mas/**/__pycache__/**

# Keep ignore files visible for tooling/debug
!.gcloudignore
!.dockerignore
